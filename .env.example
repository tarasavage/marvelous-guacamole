# OpenAI API key (required for PDF summarization)
OPENAI_API_KEY=

# Backend data directory (uploads + SQLite)
DATA_DIR=./data

# Celery broker
REDIS_URL=redis://redis:6379/0

# Logging (backend + Celery worker)
LOG_LEVEL=INFO
# true: write prompt/response JSON under DATA_DIR/debug/<document_id>/
DEBUG_LLM=false

# Frontend API base URL (browser-side)
VITE_API_URL=http://localhost:8000
